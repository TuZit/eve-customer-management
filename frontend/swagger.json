  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "service": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CustomerAccount": {
        "type": "object",
        "required": [
          "id",
          "accountNumber",
          "customerCode",
          "accountName",
          "accountKind",
          "customerSegment",
          "accountType",
          "status",
          "contacts",
          "addresses",
          "externalReferences",
          "classifications",
          "relationships",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Internal technical primary key"
          },
          "accountNumber": {
            "type": "string",
            "description": "CRM account number, e.g. ACC-000001"
          },
          "customerCode": {
            "type": "string",
            "description": "Unique dealer/customer business code"
          },
          "accountName": {
            "type": "string"
          },
          "accountKind": {
            "type": "string",
            "enum": ["ORGANIZATION", "PERSON"]
          },
          "customerSegment": {
            "type": "string",
            "enum": ["B2B", "B2C"]
          },
          "accountType": {
            "type": "string",
            "enum": [
              "DEALER",
              "SHOWROOM",
              "B2B_CUSTOMER",
              "B2C_CUSTOMER",
              "ONLINE_CUSTOMER",
              "PARTNER",
              "INDIVIDUAL",
              "COMPANY"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["PENDING", "ACTIVE", "INACTIVE", "SUSPENDED", "ARCHIVED"]
          },
          "parentAccountId": {
            "type": "string"
          },
          "parentCustomerCode": {
            "type": "string"
          },
          "taxCode": {
            "type": "string"
          },
          "businessRegistrationNo": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "website": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "regionCode": {
            "type": "string"
          },
          "territoryCode": {
            "type": "string"
          },
          "ownerUserId": {
            "type": "string"
          },
          "defaultBillingAddressId": {
            "type": "string"
          },
          "defaultShippingAddressId": {
            "type": "string"
          },
          "defaultBusinessLocationAddressId": {
            "type": "string"
          },
          "businessProfile": {
            "$ref": "#/components/schemas/BusinessAccountProfile"
